# Dros CRM — Variáveis de ambiente
# Copie para .env e preencha os valores. Não commitar .env real.

# Secret pra assinar JWTs. Gera um aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Porta do servidor Express. Default: 3002
PORT=3002

# === Integração WhatsApp (Meta Cloud API) ===
# Token permanente de acesso à Graph API (gerado no Business Manager → System Users).
# Usado pra enviar mensagens via webhook outbound.
META_ACCESS_TOKEN=

# Token customizado pra verificar webhooks de entrada da Meta.
# Defina qualquer string secreta — o mesmo valor é configurado no painel da Meta.
META_VERIFY_TOKEN=

# === Anthropic (Claude Haiku 4.5) — para Agentes de IA ===
# ATENCAO: a chave Anthropic agora e POR CONTA (cada cliente cadastra a propria em Integracoes).
# Esta var global NAO e mais usada pelos fluxos de cliente (nao ha fallback): conta sem chave nao roda IA.
# Mantida so pra utilitarios/dev (ex: smokeTest manual). Pode deixar vazia em producao.
ANTHROPIC_API_KEY=

# === Deepgram (Nova-3 PT-BR) — STT pra agentes responderem audios ===
# Cria conta em console.deepgram.com → gera API key.
# So usada quando o agente tem responds_to_audio=1. Custo $0.0043/min.
# Se nao definida, agentes nao transcrevem (caem no decline_message + handoff).
DEEPGRAM_API_KEY=
